<header class="site-header" id="site-header" role="banner">
  <div class="header__inner container">

    <a href="/" class="header__logo" aria-label="StageHaus Productions — home">
      <svg class="header__logo-mark-svg" viewBox="0 0 32 32" fill="none"
           xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M16 15 L31 31 L1 31 Z" fill="rgba(139,92,246,0.06)"/>
        <line x1="16" y1="15" x2="1"  y2="31" stroke="rgba(139,92,246,0.3)" stroke-width="0.75" stroke-linecap="round"/>
        <line x1="16" y1="15" x2="31" y2="31" stroke="rgba(139,92,246,0.3)" stroke-width="0.75" stroke-linecap="round"/>
        <line x1="0" y1="31" x2="32" y2="31" stroke="rgba(139,92,246,0.5)" stroke-width="1" stroke-linecap="round"/>
        <polygon points="16,1 23,8 16,15 9,8" fill="rgba(139,92,246,0.08)" stroke="#8B5CF6" stroke-width="1.5" stroke-linejoin="round"/>
        <polygon points="16,4.5 19.5,8 16,11.5 12.5,8" fill="#8B5CF6" opacity="0.45"/>
        <g class="logo-bulb">
          <circle cx="16" cy="8" r="5"   fill="rgba(196,181,253,0.18)"/>
          <circle cx="16" cy="8" r="3"   fill="rgba(216,204,255,0.45)"/>
          <circle cx="16" cy="8" r="1.8" fill="rgba(237,233,254,0.97)"/>
          <circle cx="16" cy="8" r="0.9" fill="#FFFFFF"/>
        </g>
      </svg>
      <span class="header__logo-wordmark">
        <span class="header__logo-name">StageHaus</span>
        <span class="header__logo-prod">Productions</span>
      </span>
    </a>

    <nav class="header__nav" aria-label="Primary navigation">
      <ul class="header__nav-list" role="list">

        <li class="header__nav-item">
          <a href="/"
             class="header__nav-link{% if currentPage == 'home' %} is-active{% endif %}"
             {% if currentPage == 'home' %}aria-current="page"{% endif %}>
            Home
          </a>
        </li>

        <li class="header__nav-item">
          <a href="/about/"
             class="header__nav-link{% if currentPage == 'about' %} is-active{% endif %}"
             {% if currentPage == 'about' %}aria-current="page"{% endif %}>
            About
          </a>
        </li>

        <li class="header__nav-item header__nav-item--dropdown">
          <button class="header__nav-link header__dropdown-trigger"
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-controls="services-dropdown">
            Services
            <svg class="header__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            </svg>
          </button>

          <div class="header__dropdown" id="services-dropdown" role="menu" aria-label="Services">
            <div class="header__dropdown-inner">

              <div class="header__dropdown-grid">

                <a href="/artist-management/"
                   class="header__dropdown-item{% if currentPage == 'artist-management' %} is-active{% endif %}"
                   role="menuitem">
                  <div class="header__dropdown-item__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><rect x="9" y="2" width="6" height="11" rx="3"/><path d="M5 10a7 7 0 0 0 14 0"/><line x1="12" y1="17" x2="12" y2="21"/><line x1="8" y1="21" x2="16" y2="21"/></svg>
                  </div>
                  <div class="header__dropdown-item__body">
                    <span class="header__dropdown-item__title">Artist Management</span>
                    <span class="header__dropdown-item__sub">Strategy, booking & career development</span>
                  </div>
                </a>

                <a href="/booking-strategy/"
                   class="header__dropdown-item{% if currentPage == 'booking-strategy' %} is-active{% endif %}"
                   role="menuitem">
                  <div class="header__dropdown-item__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 15l2 2 4-4"/></svg>
                  </div>
                  <div class="header__dropdown-item__body">
                    <span class="header__dropdown-item__title">Booking Strategy</span>
                    <span class="header__dropdown-item__sub">Routing, negotiation & promoter relations</span>
                  </div>
                </a>

                <a href="/show-logistics/"
                   class="header__dropdown-item{% if currentPage == 'show-logistics' %} is-active{% endif %}"
                   role="menuitem">
                  <div class="header__dropdown-item__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg>
                  </div>
                  <div class="header__dropdown-item__body">
                    <span class="header__dropdown-item__title">Show Logistics</span>
                    <span class="header__dropdown-item__sub">Load-in to load-out, covered</span>
                  </div>
                </a>

                <a href="/merch-operations/"
                   class="header__dropdown-item{% if currentPage == 'merch-operations' %} is-active{% endif %}"
                   role="menuitem">
                  <div class="header__dropdown-item__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                  </div>
                  <div class="header__dropdown-item__body">
                    <span class="header__dropdown-item__title">Merch Operations</span>
                    <span class="header__dropdown-item__sub">Design, sell & track your merch</span>
                  </div>
                </a>

                <a href="/website-development/"
                   class="header__dropdown-item{% if currentPage == 'website-development' %} is-active{% endif %}"
                   role="menuitem">
                  <div class="header__dropdown-item__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                  </div>
                  <div class="header__dropdown-item__body">
                    <span class="header__dropdown-item__title">Website Development</span>
                    <span class="header__dropdown-item__sub">Artist sites, EPKs & merch stores</span>
                  </div>
                </a>

                <a href="/contact/"
                   class="header__dropdown-item"
                   role="menuitem"
                   style="background: var(--electric-dim); border-color: var(--electric-rim);">
                  <div class="header__dropdown-item__icon" aria-hidden="true"
                       style="border-color: var(--electric-rim); background: rgba(139,92,246,.12);">
                    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  </div>
                  <div class="header__dropdown-item__body">
                    <span class="header__dropdown-item__title" style="color: var(--electric-lt);">Work With Us</span>
                    <span class="header__dropdown-item__sub">Start a conversation today</span>
                  </div>
                </a>

              </div>

              <div class="header__dropdown-soon">
                <span class="header__dropdown-soon-label">Coming Soon</span>
                <span class="header__dropdown-soon-item">Event Production</span>
                <span class="header__dropdown-soon-item">Artist Hospitality</span>
                <span class="header__dropdown-soon-item">Vendor Coordination</span>
                <span class="header__dropdown-soon-item">Festival Operations</span>
                <span class="header__dropdown-soon-item">Creative Direction</span>
              </div>

              <div class="header__dropdown-footer">
                <p>10+ years of production experience. Nationwide booking.</p>
                <a href="/about/">About StageHaus &rarr;</a>
              </div>

            </div>
          </div>
        </li>

        <li class="header__nav-item">
          <a href="/contact/"
             class="header__nav-link{% if currentPage == 'contact' %} is-active{% endif %}"
             {% if currentPage == 'contact' %}aria-current="page"{% endif %}>
            Contact
          </a>
        </li>

      </ul>
    </nav>

    <div class="header__actions">
      <a href="/contact/" class="btn btn--primary header__cta">Get in Touch</a>
      <button class="header__hamburger"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="mobile-menu">
        <span class="header__bar"></span>
        <span class="header__bar"></span>
        <span class="header__bar"></span>
      </button>
    </div>

  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
  <div class="mobile-menu__inner">
    <div class="mobile-menu__top">
      <a href="/" class="header__logo">
        <svg class="header__logo-mark-svg" viewBox="0 0 32 32" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M16 15 L31 31 L1 31 Z" fill="rgba(139,92,246,0.06)"/>
          <line x1="16" y1="15" x2="1"  y2="31" stroke="rgba(139,92,246,0.3)" stroke-width="0.75" stroke-linecap="round"/>
          <line x1="16" y1="15" x2="31" y2="31" stroke="rgba(139,92,246,0.3)" stroke-width="0.75" stroke-linecap="round"/>
          <line x1="0" y1="31" x2="32" y2="31" stroke="rgba(139,92,246,0.5)" stroke-width="1" stroke-linecap="round"/>
          <polygon points="16,1 23,8 16,15 9,8" fill="rgba(139,92,246,0.08)" stroke="#8B5CF6" stroke-width="1.5" stroke-linejoin="round"/>
          <polygon points="16,4.5 19.5,8 16,11.5 12.5,8" fill="#8B5CF6" opacity="0.45"/>
          <g class="logo-bulb">
            <circle cx="16" cy="8" r="5"   fill="rgba(196,181,253,0.18)"/>
            <circle cx="16" cy="8" r="3"   fill="rgba(216,204,255,0.45)"/>
            <circle cx="16" cy="8" r="1.8" fill="rgba(237,233,254,0.97)"/>
            <circle cx="16" cy="8" r="0.9" fill="#FFFFFF"/>
          </g>
        </svg>
        <span class="header__logo-wordmark">
          <span class="header__logo-name">StageHaus</span>
          <span class="header__logo-prod">Productions</span>
        </span>
      </a>
      <button class="mobile-menu__close" aria-label="Close navigation">&times;</button>
    </div>

    <a href="/" class="mobile-menu__link{% if currentPage == 'home' %} is-active{% endif %}">Home</a>
    <a href="/about/" class="mobile-menu__link{% if currentPage == 'about' %} is-active{% endif %}">About</a>

    <div class="mobile-menu__divider">Active Services</div>

    <a href="/artist-management/" class="mobile-menu__link mobile-menu__link--service{% if currentPage == 'artist-management' %} is-active{% endif %}">Artist Management</a>
    <a href="/booking-strategy/"  class="mobile-menu__link mobile-menu__link--service{% if currentPage == 'booking-strategy' %} is-active{% endif %}">Booking Strategy</a>
    <a href="/show-logistics/"    class="mobile-menu__link mobile-menu__link--service{% if currentPage == 'show-logistics' %} is-active{% endif %}">Show Logistics</a>
    <a href="/merch-operations/"  class="mobile-menu__link mobile-menu__link--service{% if currentPage == 'merch-operations' %} is-active{% endif %}">Merch Operations</a>
    <a href="/website-development/" class="mobile-menu__link mobile-menu__link--service{% if currentPage == 'website-development' %} is-active{% endif %}">Website Development</a>

    <div class="mobile-menu__divider">Coming Soon</div>

    <span class="mobile-menu__link mobile-menu__link--soon">Event Production <span class="mobile-menu__badge">Soon</span></span>
    <span class="mobile-menu__link mobile-menu__link--soon">Artist Hospitality <span class="mobile-menu__badge">Soon</span></span>
    <span class="mobile-menu__link mobile-menu__link--soon">Festival Operations <span class="mobile-menu__badge">Soon</span></span>
    <span class="mobile-menu__link mobile-menu__link--soon">Creative Direction <span class="mobile-menu__badge">Soon</span></span>

    <div class="mobile-menu__cta">
      <a href="/contact/" class="btn btn--primary btn--full">Get in Touch</a>
    </div>
  </div>
</div>

<div class="mobile-menu__overlay" id="mobile-overlay" aria-hidden="true"></div>
