          {% for row in rows %}
            <circle cx="{{ col }}" cy="{{ row }}" r="1.2" fill="rgba(139,92,246,0.12)"/>
          {% endfor %}
        {% endfor %}
      </g>

      {# ── Spotlight source — PAR can at upper right ── #}
