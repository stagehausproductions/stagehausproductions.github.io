        <line x1="380" y1="365" x2="340" y2="395" stroke="rgba(139,92,246,0.08)" stroke-width="1"/>
        <line x1="420" y1="365" x2="460" y2="395" stroke="rgba(139,92,246,0.08)" stroke-width="1"/>
        <line x1="460" y1="365" x2="420" y2="395" stroke="rgba(139,92,246,0.08)" stroke-width="1"/>
        <line x1="500" y1="365" x2="540" y2="395" stroke="rgba(139,92,246,0.08)" stroke-width="1"/>
        <line x1="540" y1="365" x2="500" y2="395" stroke="rgba(139,92,246,0.08)" stroke-width="1"/>
        <line x1="580" y1="365" x2="620" y2="395" stroke="rgba(139,92,246,0.06)" stroke-width="1"/>
        <line x1="620" y1="365" x2="580" y2="395" stroke="rgba(139,92,246,0.06)" stroke-width="1"/>
        {# Hanging drop lines — lights hanging from truss #}
        <line x1="360" y1="395" x2="360" y2="440" stroke="rgba(139,92,246,0.15)" stroke-width="1"/>
        <line x1="440" y1="395" x2="440" y2="470" stroke="rgba(139,92,246,0.15)" stroke-width="1"/>
        <line x1="520" y1="395" x2="520" y2="450" stroke="rgba(139,92,246,0.15)" stroke-width="1"/>
        <line x1="600" y1="395" x2="600" y2="460" stroke="rgba(139,92,246,0.1)"  stroke-width="1"/>
        {# Light fixture heads at bottom of drops #}
        <polygon points="360,440 368,455 352,455" stroke="rgba(139,92,246,0.25)" stroke-width="1" fill="rgba(139,92,246,0.06)"/>
        <polygon points="440,470 448,485 432,485" stroke="rgba(139,92,246,0.25)" stroke-width="1" fill="rgba(139,92,246,0.06)"/>
        <polygon points="520,450 528,465 512,465" stroke="rgba(139,92,246,0.25)" stroke-width="1" fill="rgba(139,92,246,0.06)"/>
        <polygon points="600,460 608,475 592,475" stroke="rgba(139,92,246,0.18)" stroke-width="1" fill="rgba(139,92,246,0.04)"/>
      </g>

      {# ── Floating geometric accents ── #}
      <g class="hero-dot-group">
        {# Hexagon #}
        <polygon points="180,520 200,508 220,520 220,544 200,556 180,544"
                 stroke="rgba(139,92,246,0.18)" stroke-width="1" fill="none"/>
        {# Small diamond #}
        <polygon points="420,620 432,640 420,660 408,640"
