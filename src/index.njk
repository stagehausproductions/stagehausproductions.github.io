        <linearGradient id="fadeBottom" x1="0" y1="0" x2="0" y2="1">
          <stop offset="70%" stop-color="rgba(8,10,12,0)" />
          <stop offset="100%" stop-color="rgba(8,10,12,1)" />
        </linearGradient>
      </defs>
      <rect x="0" y="0" width="700" height="900" fill="url(#fadeBottom)"/>

    </svg>
