        <line x1="620" y1="260" x2="640" y2="260" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
        {# Scattered dots — "sparks" #}
        <circle cx="160" cy="440" r="2" fill="rgba(139,92,246,0.3)"/>
        <circle cx="290" cy="560" r="1.5" fill="rgba(139,92,246,0.25)"/>
        <circle cx="470" cy="680" r="2" fill="rgba(139,92,246,0.2)"/>
        <circle cx="380" cy="320" r="1.5" fill="rgba(139,92,246,0.22)"/>
        <circle cx="650" cy="500" r="2" fill="rgba(139,92,246,0.18)"/>
        <circle cx="560" cy="750" r="1.5" fill="rgba(139,92,246,0.15)"/>
      </g>

      {# ── Bottom gradient fade so art blends into section below ── #}
