      <circle class="hero-ring"   cx="540" cy="100" r="290" stroke="rgba(139,92,246,0.06)" stroke-width="1" fill="none"/>
      <circle class="hero-ring-2" cx="540" cy="100" r="210" stroke="rgba(139,92,246,0.08)" stroke-width="1" fill="none"/>
      <circle class="hero-ring-2" cx="540" cy="100" r="140" stroke="rgba(139,92,246,0.11)" stroke-width="1.5" fill="none"/>
      <circle class="hero-ring-3" cx="540" cy="100" r="82"  stroke="rgba(139,92,246,0.16)" stroke-width="1.5" fill="none"/>
      <circle class="hero-ring-3" cx="540" cy="100" r="38"  stroke="rgba(139,92,246,0.22)" stroke-width="1" fill="none"/>

      {# Spotlight fixture — diamond/lens shape #}
